# Copy to `.env` and fill in real values. Never commit secrets.
#
# When running via docker-compose, the api/web containers pick up env vars
# from this file at the workspace root. POSTGRES_* drive the postgres
# container; the api container's DATABASE_URL is constructed from them.

# ─── DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_DB=kigaliweshare
POSTGRES_USER=kgs
POSTGRES_PASSWORD=                       # required — long random string

# Used only when running api outside Docker (local pnpm dev). Inside docker
# compose this is overridden by POSTGRES_*.
DATABASE_URL=postgresql://kgs:CHANGE_ME@localhost:5432/kigaliweshare


# ─── API SERVER ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
LOG_LEVEL=info


# ─── AUTH (Clerk) ─────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=                        # required — sk_test_… or sk_live_…
VITE_CLERK_PUBLISHABLE_KEY=              # required — pk_test_… or pk_live_…
VITE_CLERK_PROXY_URL=                    # optional — only when using Clerk's proxy feature


# ─── WEB PUSH (VAPID) ─────────────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=                        # required — server-side AND exposed via /catalog/config
VAPID_PRIVATE_KEY=                       # required — server-side only
VAPID_SUBJECT=mailto:pilot@kigaliweshare.rw


# ─── EMAIL (optional) ─────────────────────────────────────────────────────────
# Push notifications work without these.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=KigaliWeShare <pilot@kigaliweshare.rw>


# ─── MTN MOMO COLLECTIONS API ─────────────────────────────────────────────────
# Required only when monetization (serviceFeeEnabled) is on.
# Sign up: https://momodeveloper.mtn.com → Profile → Subscriptions
MOMO_COLLECTION_PRIMARY_KEY=             # subscription key
MOMO_COLLECTION_API_USER=                # API user UUID
MOMO_COLLECTION_API_KEY=                 # API key
MOMO_CALLBACK_URL=                       # https://<your-domain>/api/payments/callback
MOMO_TARGET_ENVIRONMENT=sandbox          # sandbox | rwandamtn
MOMO_CURRENCY=RWF


# ─── FRONTEND BUILD ───────────────────────────────────────────────────────────
BASE_PATH=/                              # / unless served from a sub-path


# ─── DOCKER ───────────────────────────────────────────────────────────────────
WEB_PORT=80                              # host port nginx listens on
